# Configurações do Banco de Dados PostgreSQL (Docker local)
POSTGRES_USER=adotai_user
POSTGRES_PASSWORD=adotai_password
POSTGRES_DB=adotai_db

# String de Conexão com o Banco de Dados do Backend (Docker usa o service 'db', local usa 'localhost')
# Para rodar backend localmente fora do docker (npm run start:dev):
DATABASE_URL=postgresql://adotai_user:adotai_password@localhost:5432/adotai_db

# Configurações de Segurança do Backend
JWT_SECRET=chave_secreta_jwt_desenvolvimento_local_adotai_2026
PORT=8000
